# Copy this file to webapp/.env and fill in real values.
# Never commit .env — it is already covered by .gitignore.
#
# DIFY_MOCK_MODE=true  →  full ETL flow runs with synthetic data (no Dify needed)
# DIFY_MOCK_MODE=false →  calls real Dify APIs (requires a running Dify instance)

# ── Mock switch ─────────────────────────────────────────────────────────────
DIFY_MOCK_MODE=true

# ── Database (SQLite, webapp-local) ─────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Dify endpoints & API keys ───────────────────────────────────────────────
DIFY_BASE_URL=http://localhost/v1          # self-hosted default; change for cloud
DIFY_WORKFLOW_API_KEY=                     # Extractor Workflow app API key
DIFY_DATASET_API_KEY=                      # Knowledge Base API key (separate from app keys)
DIFY_CHATBOT_API_KEY=                      # Q&A Chatbot app API key (Phase 4)

# ── Storage ──────────────────────────────────────────────────────────────────
# Path relative to webapp/ when running `next dev`. Default points to project root storage/.
STORAGE_BASE_PATH=../storage

# ── Google Gemini (data_pipeline POC scripts) ────────────────────────────────
GEMINI_API_KEY=
