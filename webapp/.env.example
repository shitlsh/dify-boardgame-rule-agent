# webapp environment variables — consumed by Next.js (webapp/ only).
# Copy this file to webapp/.env and fill in real values.
# Never commit webapp/.env — it is already covered by .gitignore.
#
# DIFY_MOCK_MODE=true  →  full ETL + chat flow uses synthetic data (no Dify needed)
# DIFY_MOCK_MODE=false →  calls real Dify APIs (requires a running Dify instance)

# ── Mock switch ───────────────────────────────────────────────────────────────
DIFY_MOCK_MODE=true

# ── Database (SQLite, local to webapp/) ──────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Dify endpoints & API keys ────────────────────────────────────────────────
DIFY_BASE_URL=http://localhost/v1          # self-hosted default; change for cloud
DIFY_WORKFLOW_API_KEY=                     # Extractor Workflow app API key
DIFY_DATASET_API_KEY=                      # Knowledge Base API key (separate from app keys)
DIFY_CHATBOT_API_KEY=                      # Q&A Chatbot app API key (rule-chatbot)
DIFY_CHATBOT_CONTEXT_INPUT=context         # must match chatbot user_input_form variable name
DIFY_WORKFLOW_MAX_FILES=20                 # must match workflow rule_files limit

# ── Dify dataset/retrieval optional defaults (backend-only; UI hidden) ───────
DIFY_DATASET_PERMISSION=only_me
DIFY_DATASET_INDEXING_TECHNIQUE=high_quality
DIFY_DATASET_PROCESS_MODE=custom
# 分段：按 Markdown 标题切（推荐，避免 # 在 .env 里被当成注释）
# 1 = 按一级标题 # ；2 = 按 ## ；3 = 按 ###
DIFY_DATASET_HEADING_LEVEL=1
# 高级：若自定义分隔符，必须加双引号，否则 \n# 会在 # 处被截断，只剩换行 → 一行一段
# DIFY_DATASET_SEGMENT_SEPARATOR="\n# "
DIFY_DATASET_SEGMENT_MAX_TOKENS=1000
DIFY_DATASET_PREPROC_REMOVE_EXTRA_SPACES=true
DIFY_DATASET_PREPROC_REMOVE_URLS_EMAILS=false
DIFY_RETRIEVE_SEARCH_METHOD=semantic_search
DIFY_RETRIEVE_RERANKING_ENABLE=false
DIFY_RETRIEVE_TOP_K=10
DIFY_RETRIEVE_SCORE_THRESHOLD_ENABLED=true
DIFY_RETRIEVE_SCORE_THRESHOLD=0.3

# ── Storage ───────────────────────────────────────────────────────────────────
# Path relative to webapp/ directory when running `next dev`.
# Default points to <project-root>/storage/
STORAGE_BASE_PATH=../storage
