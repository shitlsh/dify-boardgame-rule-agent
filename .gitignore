# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
# data_pipeline scripts use data_pipeline/.env
data_pipeline/.env
data_pipeline/.env.*
!data_pipeline/.env.example
# webapp uses webapp/.env (also covered below)
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/
.ruff_cache/
.venv/
venv/
ENV/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Node.js (future Admin Web / tooling)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Next.js build output & runtime files — never commit
# -----------------------------------------------------------------------------
.next/
out/
webapp/.next/
webapp/out/

# -----------------------------------------------------------------------------
# Local SQLite database & Prisma engine binaries
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.db-wal
*.db-shm
webapp/prisma/dev.db
webapp/prisma/*.db

# -----------------------------------------------------------------------------
# Local .env files (webapp and root)
# -----------------------------------------------------------------------------
webapp/.env
webapp/.env.*
!webapp/.env.example

# -----------------------------------------------------------------------------
# Original rulebook assets (PDF / images) — keep folder, not contents
# POC scripts only; main storage is managed via storage/ (see below)
# -----------------------------------------------------------------------------
data_pipeline/raw/*
data_pipeline/output/*
!data_pipeline/raw/.gitkeep
!data_pipeline/output/.gitkeep

# -----------------------------------------------------------------------------
# Runtime data artifacts — large files, not suitable for Git
# storage/ is managed independently (local disk -> object storage)
# storage_manifests/ IS committed (small JSON index only)
# -----------------------------------------------------------------------------
storage/raw/*
storage/output/*
!storage/raw/.gitkeep
!storage/output/.gitkeep

# -----------------------------------------------------------------------------
# Dify volume backups — never commit
# -----------------------------------------------------------------------------
backups/

# -----------------------------------------------------------------------------
# IDE & OS
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs & temp
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
.cache/

# -----------------------------------------------------------------------------
# Dify / local exports (optional: ignore if you only version-control reviewed YAML)
# -----------------------------------------------------------------------------
# dify_config/**/*.local.yml
